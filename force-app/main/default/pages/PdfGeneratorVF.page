<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false">
    <html>
        <head>
            <script src="{!$Resource.html2pdf}"></script>
        </head>
        <body>
            <script>
                window.addEventListener("message", function(event) {
                    if (event.data && event.data.type === 'GENERATE_PDF') {
                        try {
                            if (typeof window.html2pdf === 'undefined') {
                                throw new Error("The html2pdf library failed to load.");
                            }

                            var htmlString = event.data.html;
                            var element = document.createElement('div');
                            element.innerHTML = htmlString;

                            // THE FIX: Attach the element to the DOM so it has measurable CSS!
                            document.body.appendChild(element);

                            var opt = {
                                margin:       [0, 0, 0, 0],
                                filename:     'Contract.pdf',
                                image:        { type: 'jpeg', quality: 0.98 },
                                html2canvas:  { scale: 2, useCORS: true, allowTaint: true },
                                jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' },
                                pagebreak:    { mode: ['avoid-all', 'css', 'legacy'] }
                            };

                            window.html2pdf().set(opt).from(element).outputPdf('blob').then(function(blob) {
                                var reader = new FileReader();
                                reader.readAsDataURL(blob);
                                reader.onloadend = function() {
                                    var base64data = reader.result.split(',')[1];
                                    
                                    // CLEANUP: Remove the element after the snapshot
                                    document.body.removeChild(element);
                                    
                                    window.parent.postMessage({ type: 'PDF_GENERATED', base64: base64data }, '*');
                                }
                            }).catch(function(err) {
                                // CLEANUP on error too
                                document.body.removeChild(element);
                                window.parent.postMessage({ type: 'PDF_ERROR', error: err.message }, '*');
                            });

                        } catch (e) {
                            window.parent.postMessage({ type: 'PDF_ERROR', error: e.message }, '*');
                        }
                    }
                }, false);
            </script>
        </body>
    </html>
</apex:page>