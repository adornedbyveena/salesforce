<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>49.0</apiVersion>
    <assignments>
        <name>assignNewAccountId</name>
        <label>Set New Account ID</label>
        <locationX>314</locationX>
        <locationY>755</locationY>
        <assignmentItems>
            <assignToReference>varAccountId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>createPersonAccount</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>createOpportunity</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>decisionAccountExists</name>
        <label>Account Already Exists?</label>
        <locationX>182</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>lookupPersonAccountRT</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No — Create New</defaultConnectorLabel>
        <rules>
            <name>ruleAccountFound</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varAccountId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>createOpportunity</targetReference>
            </connector>
            <label>Yes — Use Existing</label>
        </rules>
    </decisions>
    <description>When a Web-to-Lead record is created, auto-creates a Person Account (or finds existing by email) and an Opportunity with all event details, then deletes the Lead to save storage.</description>
    <environments>Default</environments>
    <formulas>
        <name>formulaCloseDate</name>
        <dataType>Date</dataType>
        <expression>IF(NOT(ISBLANK({!$Record.Event_Date__c})), {!$Record.Event_Date__c}, TODAY() + 365)</expression>
    </formulas>
    <formulas>
        <name>formulaOppName</name>
        <dataType>String</dataType>
        <expression>IF(NOT(ISBLANK({!$Record.Event_Name__c})), {!$Record.Event_Name__c}, {!$Record.FirstName} &amp; &quot; &quot; &amp; {!$Record.LastName} &amp; &quot; - Event&quot;)</expression>
    </formulas>
    <interviewLabel>Lead Auto Convert {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Lead Auto Convert</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>createOpportunity</name>
        <label>Create Opportunity</label>
        <locationX>182</locationX>
        <locationY>947</locationY>
        <connector>
            <targetReference>deleteLead</targetReference>
        </connector>
        <inputAssignments>
            <field>AccountId</field>
            <value>
                <elementReference>varAccountId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Alternative_Event_Date__c</field>
            <value>
                <elementReference>$Record.Alternative_Event_Date__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>CloseDate</field>
            <value>
                <elementReference>formulaCloseDate</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Date_Flexibility__c</field>
            <value>
                <elementReference>$Record.Date_Flexibility__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Description</field>
            <value>
                <elementReference>$Record.Event_Description__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Estimated_Budget__c</field>
            <value>
                <elementReference>$Record.Estimated_Budget__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Estimated_Guest_Count__c</field>
            <value>
                <elementReference>$Record.Estimated_Guest_Count__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Event_Type__c</field>
            <value>
                <elementReference>$Record.Event_Type__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>LeadSource</field>
            <value>
                <stringValue>Web</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>formulaOppName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Services__c</field>
            <value>
                <elementReference>$Record.Services__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>StageName</field>
            <value>
                <stringValue>New Inquiry</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Venue_WebtoLead_Form__c</field>
            <value>
                <elementReference>$Record.Venue__c</elementReference>
            </value>
        </inputAssignments>
        <object>Opportunity</object>
    </recordCreates>
    <recordCreates>
